{
  "name": "abigail-cookies",
  "version": "1.0.0",
  "private": true,
  "description": "Abigail Cookies — a recipe PWA for following cookie recipes on your phone",
  "type": "module",
  "scripts": {
    "icons": "node --experimental-strip-types scripts/generate-icons.mjs",
    "validate": "node --experimental-strip-types scripts/validate-recipes.mjs",
    "predev": "npm run validate && npm run icons",
    "dev": "vite",
    "prebuild": "npm run validate && npm run icons",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.2"
  },
  "devDependencies": {
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "typescript": "^5.5.4",
    "vite": "^5.4.6",
    "vite-plugin-pwa": "^0.20.5"
  }
}
